# All three agents run on Claude now.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-5
# Optional: enables Google's official complete font-catalog API.
GOOGLE_FONTS_API_KEY=
# Optional: enables AI-generated photographic backgrounds via Higgsfield.
# Get both values from https://cloud.higgsfield.ai/api-keys (Key ID + Key Secret, two separate values).
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
